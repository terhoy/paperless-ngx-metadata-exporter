# Paperless-ngx connection. Recommended in Docker.
PAPERLESS_BASE_URL=http://paperless.example.local:8000
PAPERLESS_API_TOKEN=replace_with_your_token

# Flask/application
APP_SECRET_KEY=change_this_to_a_long_random_string
APP_HOST=0.0.0.0
APP_PORT=5001
APP_DEFAULT_LANGUAGE=nb
APP_CONFIG_PATH=/data/config.json
APP_METADATA_TTL_SECONDS=300
APP_REQUEST_TIMEOUT_SECONDS=20
APP_MAX_EXPORT_PAGES=200

# Optional Basic Auth. Disabled by default.
APP_BASIC_AUTH_ENABLED=false
APP_BASIC_AUTH_USER=admin
APP_BASIC_AUTH_PASSWORD=change_me
